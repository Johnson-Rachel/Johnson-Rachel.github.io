---
interface Props {
	title: string;
	body: string;
	href: string;
	image: string;
}

const { href, title, body, image } = Astro.props;

---

<li class="link-card" style={{ backgroundImage: `url(${image})` }}>
    <a href={href}>
        <h2>
            <span>{title}</span>
        </h2>
    </a>
</li>
<style>
	.link-card {
    position: relative; 
    height: 33ch;
    width: 33ch;
    list-style: none;
    display: flex;
    flex-direction: column;
    padding: 1px;
    background-size: cover; 
    border-radius: 50%;
    text-align: center;
    opacity: 1;
    transition: background-color .5s;
}

.link-card:hover::after, 
.link-card:focus-within::after { 
    content: ""; 
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5); 
    border-radius: inherit; 
}

.link-card > a {
	z-index: 1;
    height: 24ch;
    width: 24ch;
    text-decoration: none;
    line-height: 1.4;
    padding: calc(3.5rem - 5px);
    border-radius: 50%;
    color: white;
    text-align: center;
}

h2 {
    margin: 10px; 
    font-size: 2rem;
}

p {
    margin-top: 0.5rem;
    margin-bottom: 0;
}

</style>
