---
interface Props {
	title: string;
	body: string;
	href: string;
	image: string;
}

const { href, title, body, image } = Astro.props;
---

<li class="link-card" style={{ backgroundImage: `url({image})` }}>
	<a href={href}>
		<h2>
			<span>{title}</span>
		</h2>
	</a>
</li>
<style>
	.link-card {
		height: 33ch;
		width: 33ch;
		list-style: none;
		display: flex;
		flex-direction: column;
		padding: 1px;
		background-size: 100%;
		border-radius: 50%;
		background-position: 100%;
		text-align: center;
		opacity: 1;
	}
	.link-card > a {
		height: 24ch;
		width: 24ch;
		text-decoration: none;
		line-height: 1.4;
		padding: calc(3.5rem - 5px);
		border-radius: 50%;
		color: white;
		background-color: #23262d;
		opacity: 1;
		text-align: center;
	}
	h2 {
		margin: 10;
		font-size: 1.5rem;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}
	p {
		margin-top: 0.5rem;
		margin-bottom: 0;
	}
	.link-card:is(:hover, :focus-within) {
		background-position: 0;
		opacity: 1;
	}
	.link-card:is(:hover, :focus-within) h2 {
		color: rgb(var(--accent-light));
	}
</style>
