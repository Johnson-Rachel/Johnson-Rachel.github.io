---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import posts from '../posts.json'
import { map } from 'astro:schema';

---

<Layout title="Rachel Johnson">
	<main>
		</svg>
		<h1 <span class="text-gradient">Rachel Johnson</span></h1>
		<p class="info">
			<a href='mailto:rachel@rachelejohnson.com'>Email</a> &#x25CB; 
			<a href='/Resume.pdf'>Resume</a> &#x25CB; 
			<a href='https://github.com/johnson-rachel/'>GitHub</a> &#x25CB; 
			<a href='/archive'>All Posts</a> &#x25CB;
			<a href='/feed.xml'>RSS</a> 
			
		</p>
		<ul role="list" class="link-card-grid">
			{
			posts.slice(0,20).map(post => <Card
				href={post.href}
				title={post.title}
				image={post.image}
			/>)
			}
		</ul>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.3;
	}
	a {
	color: var(--accent);
	text-decoration: none;
	}
	a:focus,
	a:hover {
	color: var(--accent-yellow);
	text-decoration: none;
	}
	.astro-a {
		position: absolute;
		top: -32px;
		left: 50%;
		transform: translatex(-50%);
		width: 220px;
		height: auto;
		z-index: -1;
	}
	h1 {
		font-size: 5rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: .5em;
	}
	.text-gradient {
		font-family: "Koh Santepheap", serif;
		font-weight: 700;
  		font-style: normal;
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
		padding:8px;
	}
	.info {
		font-size: 1.5em;
		margin-bottom: 1rem;
		padding: 1rem;
		border-radius: 125px;
		text-align: center;
		font-weight: 500;
	}
	.info code{
		font-size: 1.5em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
	.info strong {
		color: rgb(var(--accent-light));
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
		padding: 0;
	}
	
	@media (width <= 749px) {
		/* center a single column of circles */
		.link-card-grid{
		justify-items:center;
		}
	}
	@media (380px <= width <= 455px) {
  		/* Scale down my name so it doesn't get covered up */
		h1 {
        	font-size: 4rem;
    	}
	}
	@media (300px <= width <= 379px) {
  		/* Scale down my name so it doesn't get covered up */
		h1 {
        	font-size: 3rem;
    	}
	}
	@media (width <= 299px) {
  		/* Scale down my name so it doesn't get covered up - works down to about 240px */
		h1 {
        	font-size: 2.3rem;
    	}
	}
</style>
